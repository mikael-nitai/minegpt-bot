{
  "name": "minegpt-bot",
  "version": "1.0.0",
  "description": "Bot de Minecraft Java com Mineflayer para comandos via chat",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "check": "node scripts/check-syntax.js",
    "lint": "eslint .",
    "test:unit": "node --test",
    "test:catalog": "node scripts/check-catalog.js",
    "test:inventory": "node scripts/check-inventory.js",
    "test:skills": "node scripts/check-skills.js",
    "test:crafting": "node scripts/check-crafting.js",
    "test:placement": "node scripts/check-placement.js",
    "test:containers": "node scripts/check-containers.js",
    "test:smoke": "npm run test:catalog && npm run test:inventory && npm run test:skills && npm run test:crafting && npm run test:placement && npm run test:containers",
    "coverage": "node --test --experimental-test-coverage",
    "test": "npm run check && npm run lint && npm run test:unit && npm run test:smoke"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "minecraft-data": "^3.109.1",
    "mineflayer": "^4.37.0",
    "mineflayer-pathfinder": "^2.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1"
  }
}
